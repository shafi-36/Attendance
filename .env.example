DATABASE_URL=sqlite:///./attendance.db
SECRET_KEY=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=attendance-storage
MINIO_SECURE=false

# AI reports
HF_MODEL_NAME=Qwen/Qwen2.5-3B-Instruct
HF_MAX_NEW_TOKENS=220
AI_ENABLE_LOCAL_MODEL=false

# Email automation
EMAIL_FROM=attendai@example.local
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
HOD_EMAIL=hod@example.local
